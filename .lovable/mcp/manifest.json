{
  "version": 1,
  "sdk_version": "0.23.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://viqlsemgpkioassndauo.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "epoch-chronicle-mcp",
      "version": "0.1.0",
      "title": "Epoch Chronicle"
    },
    "tools": [
      {
        "name": "search_history",
        "title": "Search historical events",
        "description": "Search the archive's historical events by title or description substring.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Text to search for in event title/description."
            },
            "limit": {
              "description": "Max results (default 15).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_notes",
        "title": "List knowledge notes",
        "description": "List the signed-in user's knowledge notes from the Studio, most recently updated first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "How many notes to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "search": {
              "description": "Optional case-insensitive substring to match against title.",
              "type": "string"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_note",
        "title": "Get knowledge note",
        "description": "Fetch a single knowledge note (including its structured AI content) by id.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "Note UUID."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "create_note",
        "title": "Create knowledge note",
        "description": "Create a new knowledge note in the signed-in user's Studio with raw text content.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "description": "Note title."
            },
            "content": {
              "type": "string",
              "minLength": 1,
              "description": "Raw note content (markdown or plain text)."
            },
            "category": {
              "description": "Optional category label.",
              "type": "string"
            },
            "tags": {
              "description": "Optional list of tags.",
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "title",
            "content"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_bookmarks",
        "title": "List bookmarks",
        "description": "List the signed-in user's saved event/era bookmarks.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max results (default 50).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
